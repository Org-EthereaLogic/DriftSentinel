# =============================================================================
# DriftSentinel — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Databricks workspace (required for bundle commands and deployment)
# Set CATALOG and DATASET_ID at minimum.
# -----------------------------------------------------------------------------
CATALOG=your-unity-catalog-name
DATASET_ID=your-registered-dataset-id
PROFILE=

# -----------------------------------------------------------------------------
# Policy paths (required for bootstrap target)
# -----------------------------------------------------------------------------
DRIFT_POLICY=templates/drift/default_drift_policy.yml
BENCHMARK_POLICY=templates/benchmark/default_benchmark_policy.yml

# -----------------------------------------------------------------------------
# Runtime paths (injected by Databricks app at deploy time;
# set locally to point at local mounts during development)
# -----------------------------------------------------------------------------
REGISTRY_PATH=/tmp/driftsentinel_registry.json
EVIDENCE_DIR=/tmp/driftsentinel_evidence
DRIFTSENTINEL_ALLOWED_PATH_ROOTS=

# Optional overrides
REGISTRY=
LANDING_PATH=
BASELINE_PATH=

# -----------------------------------------------------------------------------
# CI / Code quality tokens (used in GitHub Actions secrets — not needed locally)
# -----------------------------------------------------------------------------
# CODECOV_TOKEN=
# SNYK_PROJECT_TOKEN=
